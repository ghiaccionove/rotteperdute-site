---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const libri = await getCollection('libri');
  return libri.map((libro) => ({
    params: { id: libro.id },
    props: { libro },
  }));
}

const { libro } = Astro.props;
const { Content } = await render(libro);
const d = libro.data;

const dettagli = [
  d.titoloOriginale && { label: 'Titolo originale', valore: d.titoloOriginale },
  d.anno && { label: 'Anno', valore: String(d.anno) },
  d.lingua && { label: 'Lingua originale', valore: d.lingua },
  d.pagine && { label: 'Pagine', valore: String(d.pagine) },
  d.isbn && { label: 'ISBN', valore: d.isbn },
].filter(Boolean) as { label: string; valore: string }[];
---

<Layout
  titolo={d.titolo}
  descrizione={d.estratto ?? `${d.titolo} di ${d.autore}, tradotto da Rotte Perdute.`}
  immagine={d.copertina}
>
  <article class="mx-auto max-w-6xl px-6 pt-12 pb-8">
    <a
      href="/libri"
      class="nav-link inline-flex items-center gap-1.5"
      style="text-transform:none;letter-spacing:0.02em;font-size:0.9rem"
      >← Torna al catalogo</a
    >

    <div class="mt-10 grid gap-12 md:grid-cols-[minmax(0,360px)_1fr] md:gap-16">
      <!-- Copertina con stesso effetto libro -->
      <div class="mx-auto w-full max-w-[300px] md:sticky md:top-28 md:self-start">
        <div class="book-link group">
          <div class="book">
            <div class="book__pages"></div>
            <div class="book__cover">
              <img
                src={d.copertina}
                alt={`Copertina di ${d.titolo}`}
                width="400"
                height="600"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Informazioni -->
      <div>
        {
          d.paese && (
            <p class="eyebrow">
              {d.paese}
              {d.anno ? ` · ${d.anno}` : ''}
            </p>
          )
        }
        <h1 class="mt-3 text-[clamp(2.2rem,5vw,3.6rem)] leading-[1.02]">
          {d.titolo}
        </h1>
        <p class="mt-4 text-[1.25rem] text-[var(--color-inchiostro-soft)]">
          di <span class="italic">{d.autore}</span>
          {d.traduttore && (
            <>
              {' '}· traduzione di <span class="italic">{d.traduttore}</span>
            </>
          )}
        </p>

        {
          dettagli.length > 0 && (
            <dl class="mt-8 grid grid-cols-2 gap-x-6 gap-y-4 border-y border-[var(--color-linea)] py-6 sm:grid-cols-3">
              {dettagli.map((x) => (
                <div>
                  <dt class="font-[var(--font-sans)] text-[0.66rem] uppercase tracking-[0.16em] text-[var(--color-fumo)]">
                    {x.label}
                  </dt>
                  <dd class="mt-1 text-[1.02rem] text-[var(--color-inchiostro)]">
                    {x.valore}
                  </dd>
                </div>
              ))}
            </dl>
          )
        }

        <!-- Sinossi -->
        <div class="prosa mt-10">
          <Content />
        </div>

        <!-- Acquisto -->
        {
          (d.cartaceo.length > 0 || d.ebook.length > 0) && (
            <div class="mt-12 rounded-2xl border border-[var(--color-linea)] bg-[var(--color-carta)] p-7">
              <p class="eyebrow">Dove acquistarlo</p>

              {d.cartaceo.length > 0 && (
                <div class="mt-5">
                  <h3 class="font-[var(--font-sans)] text-[0.82rem] font-semibold tracking-[0.04em] text-[var(--color-inchiostro)]">
                    Copertina flessibile
                  </h3>
                  <div class="mt-3 flex flex-wrap gap-2.5">
                    {d.cartaceo.map((s) => (
                      <a
                        href={s.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="store-btn"
                      >
                        {s.logo ? (
                          <img src={s.logo} alt={s.nome} height="22" />
                        ) : (
                          s.nome
                        )}
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {d.ebook.length > 0 && (
                <div class="mt-6">
                  <h3 class="font-[var(--font-sans)] text-[0.82rem] font-semibold tracking-[0.04em] text-[var(--color-inchiostro)]">
                    Ebook
                  </h3>
                  <div class="mt-3 flex flex-wrap gap-2.5">
                    {d.ebook.map((s) => (
                      <a
                        href={s.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="store-btn"
                      >
                        {s.logo ? (
                          <img src={s.logo} alt={s.nome} height="22" />
                        ) : (
                          s.nome
                        )}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )
        }
      </div>
    </div>
  </article>
</Layout>

<style>
  .store-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.5rem;
    height: 3rem;
    padding: 0 1rem;
    border-radius: 10px;
    border: 1px solid var(--color-linea);
    background: var(--color-crema);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-inchiostro);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .store-btn:hover {
    transform: translateY(-2px);
    border-color: var(--color-terracotta);
    box-shadow: 0 8px 18px -10px rgba(33, 29, 26, 0.4);
  }
  .store-btn img {
    height: 22px;
    width: auto;
    object-fit: contain;
  }
</style>
