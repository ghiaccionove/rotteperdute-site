---
import Layout from '../layouts/Layout.astro';
---

<Layout
  titolo="Chi Siamo"
  descrizione="Rotte Perdute Traduzioni: un progetto editoriale indipendente dedicato ai classici dimenticati e agli autori inediti."
>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-10">
    <p class="eyebrow reveal">Chi siamo</p>
    <h1 class="reveal mt-3 text-[clamp(2.4rem,6vw,4.5rem)] leading-[1]">
      Una casa editrice<br />
      <em class="text-[var(--color-terracotta)]">controcorrente.</em>
    </h1>

    <div class="prosa reveal mt-10">
      <p>
        <strong>Rotte Perdute Traduzioni</strong> è un progetto editoriale
        indipendente che riporta alla luce vecchie opere mai tradotte in
        italiano.
      </p>
      <p>
        Attraverso un lavoro accurato di ricerca e traduzione, diamo voce a
        classici dimenticati e storie inedite per il pubblico italiano, 
        che meritano una seconda vita.
      </p>

      <h2>Contatti</h2>
      <p>
        Per informazioni, collaborazioni o semplicemente per conoscerci meglio:
      </p>
    </div>

    <div class="reveal mt-8 flex flex-wrap gap-4">
      <a href="mailto:rotte.perdute@gmx.com" class="btn btn-primario"
        >Scrivici una mail</a
      >
      <a
        href="https://www.instagram.com/rotteperdute/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost">Seguici su Instagram</a
      >
    </div>

    <p class="reveal mt-8 text-[var(--color-inchiostro-soft)]">
      Seguici sui nostri canali per restare aggiornato sulle nuove pubblicazioni
      e scoprire le storie dietro ogni traduzione.
    </p>
  </section>
</Layout>
