---
const anno = new Date().getFullYear();
---

<footer class="mt-28 border-t border-[var(--color-linea)] bg-[var(--color-crema-scuro)]">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-10 px-6 py-16 md:flex-row md:items-start md:justify-between"
  >
    <div class="max-w-sm">
      <p class="font-[var(--font-display)] text-2xl">Rotte Perdute</p>
      <p class="mt-3 text-[0.98rem] text-[var(--color-inchiostro-soft)]">
        Progetto editoriale indipendente che riporta alla luce opere mai
        tradotte in italiano.
      </p>
    </div>

    <div class="flex flex-col gap-3">
      <span class="eyebrow">Contatti</span>
      <a
        href="mailto:rotte.perdute@gmx.com"
        class="text-[var(--color-inchiostro-soft)] transition-colors hover:text-[var(--color-terracotta)]"
        >rotte.perdute@gmx.com</a
      >
      <a
        href="https://www.instagram.com/rotteperdute/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-inchiostro-soft)] transition-colors hover:text-[var(--color-terracotta)]"
        >Instagram · @rotteperdute</a
      >
    </div>
  </div>

  <div class="border-t border-[var(--color-linea)]">
    <div
      class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-6 text-[0.78rem] text-[var(--color-fumo)] sm:flex-row sm:justify-between"
    >
      <span>© {anno} Rotte Perdute Traduzioni</span>
      <span>Letteratura ritrovata, una rotta alla volta.</span>
    </div>
  </div>
</footer>
